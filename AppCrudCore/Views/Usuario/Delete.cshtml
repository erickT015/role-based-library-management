@model AppCrudCore.Models.ViewModels.Usuario.UsuarioDeleteViewModel

@{
    ViewData["Title"] = "Borrar Usuario";
}

<section class="main-container">

    <div class="glass-card" style="max-width:850px;">

        <!-- HEADER -->
        <div class="form-header">

            <div class="avatar danger-avatar">
                @Model.NombreCompleto.Substring(0, 1)
            </div>

            <h1 class="title text-danger">
                Eliminar Usuario
            </h1>

            <p class="subtitle">
                Esta acción no se puede deshacer
            </p>

        </div>

        <div class="separator"></div>


        <!-- WARNING -->
        <div class="summary-card danger-zone">

            ⚠️ Estás a punto de eliminar permanentemente este usuario.

        </div>


        <!-- INFO -->
        <h3 class="subtitle text-center">
            Información del Usuario
        </h3>

        <div class="form-grid">

            <div class="detail-block">
                <span class="field-label">Nombre</span>
                <div class="detail-value">
                    @Model.NombreCompleto
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Correo</span>
                <div class="detail-value">
                    @Model.Correo
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Cédula</span>
                <div class="detail-value">
                    @Model.Cedula
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Teléfono</span>
                <div class="detail-value">
                    @Model.Telefono
                </div>
            </div>

            <div class="detail-block full-width">
                <span class="field-label">Dirección</span>
                <div class="detail-value">
                    @Model.Direccion
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Rol</span>
                <div class="detail-value">
                    @Model.Rol?.Nombre
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Estado</span>

                @if (Model.Activo)
                {
                    <span class="status-pill completado">
                        Activo
                    </span>
                }
                else
                {
                    <span class="status-pill pendiente">
                        Inactivo
                    </span>
                }

            </div>

        </div>

        <div class="separator"></div>


        <!-- ACTIONS -->
        <form asp-action="Delete">

            <input type="hidden" asp-for="IdUsuario" />

            <div class="actions">

                <button type="submit"
                        class="btn-custom btnDelete">
                    🗑️ Eliminar Usuario
                </button>

                <a asp-action="Index"
                   class="btn-back">
                    ← Cancelar
                </a>

            </div>

        </form>

    </div>

</section>
<style>
    .danger-zone {
        background: rgba(239,68,68,.15);
        border: 1px dashed rgba(239,68,68,.5);
        color: #fca5a5;
        text-align: center;
        font-weight: 600;
    }

    .danger-avatar {
        background: linear-gradient( 135deg, #ef4444, #dc2626 );
        box-shadow: 0 0 25px rgba(239,68,68,.5);
    }
</style>