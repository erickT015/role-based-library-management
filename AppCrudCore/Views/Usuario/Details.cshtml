@model AppCrudCore.Models.ViewModels.Usuario.UsuarioDetailsViewModel

@{
    ViewData["Title"] = "Detalle Usuario";
}

<section class="main-container">

    <div class="glass-card table-page">

        <div class="profile-layout">

            <div>

                <div class="form-header">

                    <div class="avatar" style="width:90px;height:90px;font-size:36px;">
                        @(Model.NombreCompleto?.Substring(0, 1) ?? "?")
                    </div>

                    <h1 class="title">
                        @(Model.NombreCompleto ?? "Usuario")
                    </h1>

                    <span class="badge-role">
                        @(Model.RolNombre ?? "Sin Rol")
                    </span>

                </div>

                <div class="separator"></div>

                <h3 class="subtitle text-center">
                    Información Personal
                </h3>

                <div class="form-grid">

                    <div class="detail-block">
                        <span class="field-label">Correo</span>
                        <div class="detail-value">
                            @(Model.Correo ?? "—")
                        </div>
                    </div>

                    <div class="detail-block">
                        <span class="field-label">Cédula</span>
                        <div class="detail-value">
                            @(Model.Cedula ?? "—")
                        </div>
                    </div>

                    <div class="detail-block">
                        <span class="field-label">Teléfono</span>
                        <div class="detail-value">
                            @(Model.Telefono ?? "—")
                        </div>
                    </div>

                    <div class="detail-block full-width">
                        <span class="field-label">Dirección</span>
                        <div class="detail-value">
                            @(Model.Direccion ?? "—")
                        </div>
                    </div>

                </div>

                <div class="separator"></div>

                <h3 class="subtitle text-center">
                    Actividad
                </h3>

                <div class="summary-card">

                    <div class="summary-item">
                        <span class="label">Registro</span>
                        <span class="value">
                            @(Model.FechaRegistro?.ToString("dd/MM/yyyy") ?? "—")
                        </span>
                    </div>

                    <div class="summary-item">
                        <span class="label">Último acceso</span>
                        <span class="value">
                            @(Model.UltimoLogin?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")
                        </span>
                    </div>

                    <div class="summary-item">
                        <span class="label">Estado</span>

                        @if (Model.Activo == true)
                        {
                            <span class="status-pill completado">Activo</span>
                        }
                        else
                        {
                            <span class="status-pill pendiente">Inactivo</span>
                        }

                    </div>

                </div>

                <div class="separator"></div>

                <div class="actions">

                    <a asp-action="Edit"
                       asp-route-id="@Model.IdUsuario"
                       class="btn-custom btnEdit">
                        ✏️ Editar Usuario
                    </a>

                    <a asp-action="Index" class="btn-back">
                        ← Volver
                    </a>

                </div>

            </div>
            <div class="stats-card">

                <h3 class="subtitle text-center">
                    Estadísticas
                </h3>

                <div class="stat-item">
                    <span>Transacciones</span>
                    <strong>@(Model.TotalTransacciones ?? 0)</strong>
                </div>

                <div class="stat-item">
                    <span>Libros movidos</span>
                    <strong>@(Model.LibrosPrestados ?? 0)</strong>
                </div>

                <div class="stat-item">
                    <span>Total gastado</span>
                    <strong>₡@(Model.TotalGastado ?? 0)</strong>
                </div>

                <div class="stat-item">
                    <span>Última actividad</span>
                    <strong>
                        @(Model.UltimaActividad?.ToString("dd/MM/yyyy") ?? "—")
                    </strong>
                </div>

            </div>

        </div>
    </div>
</section>
<style>
    .profile-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
    }

    .stats-card {
        background: rgba(79,70,229,.08);
        border: 1px solid var(--border-color);
        border-radius: 18px;
        padding: 25px;
    }

    .stat-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255,255,255,.05);
    }

        .stat-item strong {
            color: var(--accent);
            font-size: 1.2rem;
        }
</style>