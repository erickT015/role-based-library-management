@model AppCrudCore.Models.ViewModels.TransaccionBiblioteca.TransaccionBibliotecaEditViewModel

@{
    ViewData["Title"] = "Editar Operación";
}

<section class="main-container">

    <div class="glass-card">

        <!-- HEADER -->
        <div class="form-header">
            <h1 class="title">Editar Operación</h1>
            <p class="subtitle">
                Actualice únicamente la información administrativa permitida
            </p>
        </div>

        <form asp-action="Edit">

            <input type="hidden"
                   asp-for="IdTransaccionBiblioteca" />

            <div asp-validation-summary="ModelOnly"
                 class="error-text">
            </div>
            <div class="form-grid">

                <!-- ESTADO -->
                <div class="input-group">
                    <label class="field-label">
                        Estado de la Operación
                    </label>

                    <select asp-for="Estado"
                            class="custom-select">

                        <option value="">Seleccione estado</option>
                        <option value="1">Devuelto</option>
                        <option value="2">Prestado</option>
                        <option value="3">Vendido</option>
                        <option value="4">Cancelado</option>

                    </select>

                    <span asp-validation-for="Estado"
                          class="error-text"></span>
                </div>

                <!-- FECHA -->
                <div class="input-group">
                    <label class="field-label">
                        Fecha de Devolución
                    </label>

                    <input asp-for="FechaDevolucion"
                           type="date"
                           class="custom-input" />

                    <span asp-validation-for="FechaDevolucion"
                          class="error-text"></span>
                </div>

            </div>

            <!-- OBSERVACIONES -->
            <div class="input-group">
                <label class="field-label">
                    Observaciones
                </label>

                <textarea asp-for="Observaciones"
                          rows="4"
                          placeholder="Notas administrativas..."
                          class="custom-input"></textarea>

                <span asp-validation-for="Observaciones"
                      class="error-text"></span>
            </div>

            <div class="separator"></div>

            <!-- INFO BLOQUE SEGURIDAD -->
            <div class="summary-card">

                <div class="summary-item">
                    <span class="label">Modo Seguro</span>
                    <span class="value">
                        Solo campos autorizados
                    </span>
                </div>

                <div class="summary-item">
                    <span class="label">ID Operación</span>
                    <span class="value">
                        #@Model.IdTransaccionBiblioteca
                    </span>
                </div>

            </div>

            <!-- ACTIONS -->
            <div class="actions">

                <button type="submit"
                        class="btn-primary-submit">
                    Guardar Cambios
                </button>

                <a asp-action="Index"
                   class="btn-back">
                    ← Volver al listado
                </a>

            </div>

        </form>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}