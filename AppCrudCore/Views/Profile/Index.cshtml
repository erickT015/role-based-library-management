@model AppCrudCore.Models.ViewModels.Profile.ProfileIndexViewModel

@{
    ViewData["Title"] = "Mi perfil";
}

<section class="main-container">

    <div class="glass-card" style="max-width:900px;">

        <!-- HEADER -->
        <div class="form-header">

            <div class="avatar"
                 style="width:90px;height:90px;font-size:36px;">
                @Model.NombreCompleto.Substring(0, 1)
            </div>

            <h1 class="title">@Model.NombreCompleto</h1>

            <span class="badge-role">
                @Model.RolNombre
            </span>

        </div>

        <div class="separator"></div>

        <!-- INFO GRID -->
        <div class="form-grid">

            <div class="detail-block">
                <span class="field-label">Correo</span>
                <div class="detail-value">@Model.Correo</div>
            </div>

            <div class="detail-block">
                <span class="field-label">Cédula</span>
                <div class="detail-value">@Model.Cedula</div>
            </div>

            <div class="detail-block">
                <span class="field-label">Teléfono</span>
                <div class="detail-value">@Model.Telefono</div>
            </div>

            <div class="detail-block">
                <span class="field-label">Dirección</span>
                <div class="detail-value">@Model.Direccion</div>
            </div>

        </div>

        <div class="separator"></div>

        <!-- LOGIN INFO -->
        <div class="summary-card">

            <div class="summary-item">
                <span class="label">Último Acceso</span>
                <span class="value">
                    @Model.UltimoLogin
                </span>
            </div>

        </div>

        <!-- ACTIONS -->
        <div class="actions">

            <a asp-action="Edit"
               class="btn-custom btnEdit">
                ✏️ Editar Perfil
            </a>

        </div>

    </div>

</section>