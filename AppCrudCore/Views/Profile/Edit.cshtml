@model AppCrudCore.Models.ViewModels.Profile.ProfileEditViewModel

@{
    ViewData["Title"] = "Editar Perfil";
}

<section class="main-container">

    <form asp-action="Edit"
          method="post"
          class="glass-card"
          style="max-width:900px;">

        <div class="form-header">
            <h1 class="title">Editar Perfil</h1>
            <p class="subtitle">
                Actualiza tu información personal
            </p>
        </div>

        <!-- DATOS PERSONALES -->
        <div class="form-grid">

            <div class="input-group">
                <label class="field-label">
                    Nombre completo
                </label>
                <input asp-for="NombreCompleto"
                       class="custom-input"/>
            </div>

            <div class="input-group">
                <label class="field-label">
                    Teléfono
                </label>
                <input asp-for="Telefono"
                       class="custom-input"/>
            </div>

            <div class="input-group full-width">
                <label class="field-label">
                    Dirección
                </label>
                <input asp-for="Direccion"
                       class="custom-input"/>
            </div>

        </div>

        <div class="separator"></div>

        <!-- PASSWORD -->
        <h3 class="subtitle text-center">
            Seguridad
        </h3>

        <div class="form-grid">

            <div class="input-group">
                <label class="field-label">
                    Nueva contraseña
                </label>
                <input asp-for="NuevaPassword"
                       type="password"
                       class="custom-input"/>
            </div>

            <div class="input-group">
                <label class="field-label">
                    Confirmar contraseña
                </label>
                <input asp-for="ConfirmarPassword"
                       type="password"
                       class="custom-input"/>
            </div>

        </div>

        <!-- ACTIONS -->
        <div class="actions">

            <button type="submit"
                    class="btn-primary-submit">
                💾 Guardar Cambios
            </button>

            <a asp-action="Index"
               class="btn-back">
                ← Cancelar
            </a>

        </div>

    </form>

</section>