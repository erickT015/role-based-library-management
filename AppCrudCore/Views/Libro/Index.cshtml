@model IEnumerable<AppCrudCore.Models.Libro>

@{
    ViewData["Title"] = "Libros";
}

<section class="main-container">
    <div class="glass-card table-page">
        <header class="table-header">
            <div class="header-content">
                <h1 class="title">Gestioón de Libros</h1>
                <p class="subtitle">Gestiona facilmente tus libros</p>
            </div>
            <a asp-action="Create" class="btn-create"> agregar Libro</a>
        </header>
        <form method="get" class="filter-bar">
            <select name="categoriaId" asp-items="ViewBag.Categorias">
                <option value="">Todas</option>
            </select>

            <select name="activo">
                <option value="">Todos</option>
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>

            <button type="submit" class="btn-create">Filtrar</button>
        </form>

        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>
                            Portada
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Titulo)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Autor)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ISBN)
                        </th>
                        <th>
                            Año Publicación
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Resumen)
                        </th>
                        <th>
                            Precio Venta
                        </th>
                        <th>
                            Stock Total
                        </th>
                        <th>
                           Stock Préstamo
                        </th>
                        <th>
                            Stock venta
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Activo)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Categoria)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="@item.ImagenUrl"
                                         class="table-book-img" />
                                }
                                else
                                {
                                    <span class="text-muted">Sin imagen</span>
                                }
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Titulo)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Autor)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ISBN)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.AnioPublicacion)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Resumen)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.PrecioVenta)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.StockTotal)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.StockPrestamo)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.StockVenta)
                            </td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="dot-green" title="Activo"></span>
                                }
                                else
                                {
                                    <span class="dot-red" title="Inactivo"></span>
                                }
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Categoria.Nombre)
                            </td>
                            <td class="actions-cell">
                                <div class="action-buttons">
                                    <a asp-action="Edit" class="btn-custom btnEdit" asp-route-id="@item.IdLibro">Editar</a> |
                                    <a asp-action="Details" class="btn-custom btndetails" asp-route-id="@item.IdLibro">Detalles</a> |
                                    <a asp-action="Delete" class="btn-custom btnDelete"  asp-route-id="@item.IdLibro">Borrar</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
<style>
    .table-book-img {
        width: 50px;
        height: 65px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,.1);
        box-shadow: 0 4px 10px rgba(0,0,0,.3);
        transition: transform .2s ease;
    }

        .table-book-img:hover {
            transform: scale(1.15);
        }
</style>