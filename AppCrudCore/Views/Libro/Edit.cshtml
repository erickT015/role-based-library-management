@model AppCrudCore.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<section class="main-container">

    <div class="glass-card">

        <!-- HEADER -->
        <div class="form-header">
            <h1 class="title">Editar Libro</h1>
            <p class="subtitle">
                Actualiza la información del libro seleccionado
            </p>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data">

            <input type="hidden" asp-for="IdLibro" />

            <div asp-validation-summary="ModelOnly"
                 class="validation-text"></div>

            <!-- GRID -->
            <div class="form-grid">
                <div class="input-group">
                    <label class="field-label">Imagen</label>

                    <input type="file"
                           name="imagenArchivo"
                           accept="image/*"
                           class="custom-input" />
                </div>

                <div class="input-group">
                    <label asp-for="Titulo" class="field-label"></label>
                    <input asp-for="Titulo" class="custom-input" />
                    <span asp-validation-for="Titulo" class="validation-text"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Autor" class="field-label"></label>
                    <input asp-for="Autor" class="custom-input" />
                    <span asp-validation-for="Autor" class="validation-text"></span>
                </div>

                <div class="input-group">
                    <label asp-for="ISBN" class="field-label"></label>
                    <input asp-for="ISBN" class="custom-input" />
                    <span asp-validation-for="ISBN" class="validation-text"></span>
                </div>

                <div class="input-group">
                    <label asp-for="AnioPublicacion" class="field-label"></label>
                    <input asp-for="AnioPublicacion" class="custom-input" />
                    <span asp-validation-for="AnioPublicacion" class="validation-text"></span>
                </div>

                <div class="input-group">
                    <label asp-for="PrecioVenta" class="field-label"></label>
                    <input asp-for="PrecioVenta" class="custom-input" />
                </div>

                <div class="input-group">
                    <label asp-for="CategoriaId" class="field-label"></label>
                    <select asp-for="CategoriaId"
                            class="custom-select"
                            asp-items="ViewBag.CategoriaId">
                    </select>
                </div>

            </div>

            <div class="separator"></div>

            <!-- INVENTARIO -->
            <div class="inventory-section">

                <div class="input-group">
                    <label asp-for="StockTotal" class="field-label"></label>
                    <input asp-for="StockTotal" class="custom-input" />
                </div>

                <div class="input-group">
                    <label asp-for="StockPrestamo" class="field-label"></label>
                    <input asp-for="StockPrestamo" class="custom-input" />
                </div>

                <div class="input-group">
                    <label asp-for="StockVenta" class="field-label"></label>
                    <input asp-for="StockVenta" class="custom-input" />
                </div>

            </div>

            <div class="input-group">
                <label asp-for="Resumen" class="field-label"></label>
                <textarea asp-for="Resumen"
                          class="custom-input"
                          rows="3"></textarea>
            </div>

            <!-- ACTIVO -->
            <div class="input-group">
                <label class="field-label">
                    <input asp-for="Activo" />
                    Libro Activo
                </label>
            </div>

            <!-- ACTIONS -->
            <div class="actions">

                <button type="submit"
                        class="btn-primary-submit">
                    💾 Guardar Cambios
                </button>

                <a asp-action="Index"
                   class="btn-back">
                    ← Volver al listado
                </a>

            </div>

        </form>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}