@model AppCrudCore.Models.Libro

@{
    ViewData["Title"] = "Detalles del Libro";
}

<section class="main-container">

    <div class="glass-card">

        <!-- HEADER -->
        <div class="form-header">
            <h1 class="title">Detalles del Libro</h1>
            <p class="subtitle">
                Información completa del libro seleccionado
            </p>
        </div>

        <!-- INFORMACIÓN GENERAL -->
        <div class="form-grid">

            <div class="detail-block">
                <span class="field-label">Título</span>
                <div class="detail-value">
                    @Model.Titulo
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Autor</span>
                <div class="detail-value">
                    @Model.Autor
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">ISBN</span>
                <div class="detail-value">
                    @Model.ISBN
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Año Publicación</span>
                <div class="detail-value">
                    @Model.AnioPublicacion
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Categoría</span>
                <div class="detail-value">
                    @Model.Categoria?.Nombre
                </div>
            </div>

            <div class="detail-block">
                <span class="field-label">Precio Venta</span>
                <div class="detail-value price-cell">
                    ₡ @Model.PrecioVenta
                </div>
            </div>

        </div>

        <div class="separator"></div>

        <!-- RESUMEN -->
        <div class="detail-block">
            <span class="field-label">Resumen</span>
            <div class="detail-value italic">
                @Model.Resumen
            </div>
        </div>

        <div class="separator"></div>

        <!-- INVENTARIO -->
        <div class="summary-card">

            <div class="summary-item">
                <span class="label">Stock Total</span>
                <span class="value">
                    @Model.StockTotal
                </span>
            </div>

            <div class="summary-item">
                <span class="label">Préstamo</span>
                <span class="value">
                    @Model.StockPrestamo
                </span>
            </div>

            <div class="summary-item total">
                <span class="label">Venta</span>
                <span class="value">
                    @Model.StockVenta
                </span>
            </div>

        </div>

        <!-- ESTADO -->
        <div class="detail-block">
            <span class="field-label">Estado</span>

            @if (Model.Activo)
            {
                <span class="status-pill activo">
                    Activo
                </span>
            }
            else
            {
                <span class="status-pill pendiente">
                    Inactivo
                </span>
            }
        </div>

        <!-- ACTIONS -->
        <div class="actions">

            <a asp-action="Edit"
               asp-route-id="@Model.IdLibro"
               class="btn-custom btnEdit">
                ✏️ Editar
            </a>

            <a asp-action="Index"
               class="btn-custom btnDetails">
                ← Volver
            </a>

        </div>

    </div>

</section>